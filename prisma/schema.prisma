// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id String @id @default(ulid())
  title String
  content String
  thumbnail String?
  isFeatured Boolean @default(false)
  status PostStatus @default(PUBLISHED)
  createdAt DateTime @default(now())  
  updatedAt DateTime @updatedAt
  tags String[]
  views Int @default(0)
  authorId String
  comments Comment[]
  @@index([authorId])
  @@map("posts")
}


model Comment{
  id String @id @default(ulid())
  content String
  createdAt DateTime @default(now())
  authorId String
  postId String
  post Post @relation(fields: [postId],references: [id])
parentsId String?

parent Comment? @relation("CommentChildren", fields: [parentsId], references: [id])

updatedAt DateTime @updatedAt
status Status @default(APPROVED) 
@@index([authorId])
@@index([postId])
@@map("comments")

comments Comment[] @relation("CommentChildren")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Status {
  APPROVED
  REJECTED
  PENDING
}

